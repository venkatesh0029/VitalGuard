# ════════════════════════════════════════════════════════════════════════════════
# HealthGuard Backend Configuration
# ════════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────────

# Set to 'mongo' to enable MongoDB, 'inmemory' for in-memory (default)
DATABASE_PROVIDER=mongo

# MongoDB Local Setup (for development)
MONGO_URI=mongodb://localhost:27017/healthguard

# MongoDB Atlas Setup (for production/cloud)
# Replace with your actual MongoDB Atlas connection string
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/healthguard?retryWrites=true&w=majority

# ──────────────────────────────────────────────────────────────────────────────────
# EMAIL ALERTS CONFIGURATION (GMAIL)
# ──────────────────────────────────────────────────────────────────────────────────

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your Gmail email address
SMTP_USER=your-email@gmail.com

# Gmail App Password (get from: https://myaccount.google.com/apppasswords)
# 1. Enable 2-Step Verification in Google Account
# 2. Go to App passwords: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Copy the 16-character password here
SMTP_PASS=your-app-password-here

# Optional: sender name (defaults to SMTP_USER if not set)
ALERT_FROM=HealthGuard Alerts <your-email@gmail.com>

# ──────────────────────────────────────────────────────────────────────────────────
# SMS ALERTS CONFIGURATION (TWILIO)
# ──────────────────────────────────────────────────────────────────────────────────

# Twilio SID (Account ID - get from: https://console.twilio.com/)
TWILIO_SID=your-twilio-account-sid

# Twilio Auth Token (get from: https://console.twilio.com/)
TWILIO_AUTH=your-twilio-auth-token

# Twilio Phone Number (the number that will send SMS)
# Get a Twilio number at: https://console.twilio.com/phone-numbers/incoming
TWILIO_FROM=+1234567890

# ──────────────────────────────────────────────────────────────────────────────────
# SECURITY CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────────

# JWT Secret Key (change to a random string for production)
SECRET_KEY=your-secret-key-change-this-in-production

# CORS allowed origins (frontend URLs that can call this API)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ──────────────────────────────────────────────────────────────────────────────────
# ML MODEL CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────────

# Path to your ML model (if using scikit-learn pickle file)
MODEL_PATH=models/health_model.pkl

# ────────────────────────────────────────────────────────────────────────────────────
# NOTES FOR SETUP:
# ────────────────────────────────────────────────────────────────────────────────────
# 
# MONGODB SETUP:
# ─────────────────
# 1. Install MongoDB locally: https://docs.mongodb.com/manual/installation/
# 2. OR use MongoDB Atlas (free cloud): https://www.mongodb.com/cloud/atlas
# 3. Start MongoDB service (local): mongod
# 4. Connection string format:
#    - Local: mongodb://localhost:27017/healthguard
#    - Atlas: mongodb+srv://user:pass@cluster.mongodb.net/healthguard
#
# EMAIL ALERTS SETUP (Gmail):
# ─────────────────────────────
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer"
# 3. Google will generate a 16-character app password
# 4. Copy that password to SMTP_PASS above
# 5. Enable "Less secure app access" if needed: https://myaccount.google.com/lesssecureapps
#
# SMS ALERTS SETUP (Twilio):
# ──────────────────────────
# 1. Sign up for Twilio: https://www.twilio.com/try-twilio
# 2. Go to Console: https://console.twilio.com/
# 3. In "Account" menu, find "Account SID" and "Auth Token"
# 4. Get a Twilio phone number (for sending SMS)
# 5. Copy these values to the TWILIO_* variables above

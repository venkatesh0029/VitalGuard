# HealthGuard Backend Environment Variables (template)
# Copy to .env and fill values

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

MODEL_PATH=./models/health_model.pkl

MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/healthguard?retryWrites=true&w=majority

# DATABASE_PROVIDER=mongo  # Uncomment for MongoDB

